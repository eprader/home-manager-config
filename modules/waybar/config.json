{
    "mainBar": {
        "layer": "top",
        "height": 20,
        "spacing": 4,

        "modules-left": [
            "hyprland/workspaces"
        ],
        "modules-center": [
            "clock"
        ],
        "modules-right": [
            "pulseaudio",
            "backlight",
            "tray",
            "battery"
        ],
        "tray": {
            "spacing": 10
        },

        "hyprland/workspaces": {
            "format": "{name} {windows}",
            "format-window-separator": " ",
            "window-rewrite-default": "Όφ┐",
            "window-rewrite": {
                "title<(vi|vim|nvim)>": "Όγχ",
                "youtube": "ΎΖς",
                "discord": "≤░βψ",
                "spotify": "≤░ΥΘ",
                "whatsapp": "≤░Ψμ",
                "gmail": "≤░Λτ",
                "(claude|chatgpt|gemini)": "Ό╕Ξ",
                "title<.* chat .*>": "≤▒ΜΛ",
                "class<thunderbird>": "ΎΡψ",
                "class<thunar>": "≤░ξσ",
                "title<.*@johanniter.at.*>": "≤░┤λ"
            }
        },
        "backlight": {
            "format": "{percent}% {icon}",
            "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
        },
        "battery": {
            "states": {
                "warning": 30,
                "critical": 15
            },
            "format": "{capacity}% {icon}",
            "format-full": "{capacity}% {icon}",
            "format-charging": "{capacity}% ≤▒ΡΜ",
            "format-plugged": "{capacity}% ΎΘο",
            "format-alt": "{time} {icon}",
            "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
        },
        "pulseaudio": {
            "format": "{volume}% {icon}  {format_source}",
            "format-muted": "≤░ΨΒ  {format_source}",
            "format-bluetooth": "{volume}% ΎΛΦ{icon}  {format_source}",
            "format-bluetooth-muted": "≤░ΨΒ  {format_source}",
            "format-source": "{volume}% ≤░Ξυ",
            "format-source-muted": "≤░Ξφ",
            "format-icons": {
                "headphone": "ΎΑξ",
                "hands-free": "≤░θΖ",
                "headset": "Ό╣β",
                "phone": "ΎΓΧ",
                "portable": "ΎΓΧ",
                "car": "ΎΗ╣",
                "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
            },
            "on-click": "pavucontrol"
        },
        "clock": {
            "format": "{:%d.\u2009%b. %H:%M}"
        }
    }
}
